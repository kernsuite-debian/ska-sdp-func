# The Runtime Package (needed to run EveryBeam)
Package: libska-sdp-func1
Architecture: any
Multi-Arch: same
Depends: ${misc:Depends}, ${shlibs:Depends}
Description: SKA SDP Function Library - runtime
 This library contains optimized functions for radio astronomy 
 data processing used by the SKA Science Data Processor.

# The Development Package (needed to build EveryBeam)
Package: libska-sdp-func-dev
Section: libdevel
Architecture: any
Multi-Arch: same
Depends: libska-sdp-func1 (= ${binary:Version}), ${misc:Depends}
Description: SKA SDP Function Library - development files
 This package contains the header files and CMake configuration
 files required to build software against libska-sdp-func.
